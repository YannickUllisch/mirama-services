@startuml context
skinparam linetype default
skinparam nodesep 60
skinparam ranksep 70
skinparam ArrowThickness 1.3
skinparam ArrowColor #444444
skinparam ClassBorderColor #333333
skinparam ClassBackgroundColor #FFFFFF

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
SHOW_PERSON_OUTLINE()
!define FONTAWESOME https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/master/font-awesome-5
!include FONTAWESOME/users.puml

LAYOUT_WITH_LEGEND()
SHOW_PERSON_OUTLINE()

title System Context Diagram - Mirama Platform

' Actors
Person(creator, "Creative User / Manager", "Project managers, Designers and Artists managing task trees and mockups")
Person(client, "Stakeholder / Client", "Reviews visual figures and approves design iterations")
Person(admin, "Tenant Admin", "Manages own Organizations, teams and global billing/subscriptions")
Person(dev, "Developer", "Builds, maintains, and operates the Mirama platform")
Person(owner, "Business Owner", "Oversees platform direction, priorities, and ROI")
Person(support, "Support & Operations", "Ensures uptime, support, and customer success")
Person(external, "External Collaborator", "Freelancers, contractors, and reviewers with limited access")

' System Boundary
System(platform, "Mirama Platform", "Centralized Hub for Project Management & Creative Lifecycles. Manages projects, tasks, versioned mockups and multi-tenancy securely.")

' External Systems
System_Ext(idp, "Identity Provider (OIDC)", "AWS Cognito + OpenIddict / External IDPs (Google) for Global Identity")
System_Ext(storage, "Cloud Storage", "Secure storage for high-res mockups, figures and general assets such as .PDF files")
System_Ext(email, "Email Service", "Transactional alerts for mentions and approval requests")
System_Ext(messaging, "Event Bus (SNS/SQS)", "Asynchronous coordination between Microservices (Phase 2)")
System_Ext(observability, "Observability Stack", "Centralized logs and metrics for distributed services")

' Relationships
Rel(creator, platform, "Manages tasks and uploads assets", "HTTPS/Web")
Rel(client, platform, "Reviews and approves mockups", "HTTPS/Web")
Rel(admin, platform, "Configures Teams and Billing", "HTTPS/Web")
Rel(dev, platform, "Develops and operates", "DevOps/API")
Rel(owner, platform, "Sets priorities, reviews analytics", "Reports/Dashboards")
Rel(support, platform, "Monitors uptime, supports users", "Support/Monitoring")
Rel(external, platform, "Collaborates on projects, reviews assets", "HTTPS/Web")

Rel(platform, idp, "Delegates Auth & Tenant Switching to", "OIDC/JWT")
Rel(platform, storage, "Persists & retrieves visual assets via", "S3 API / Signed URLs")
Rel(platform, email, "Sends notifications via", "SMTP/API")
BiRel(platform, messaging, "Publishes & consumes domain events", "Async")
Rel(platform, observability, "Exports telemetry to", "Logs/Metrics")

SHOW_LEGEND()
@enduml